{
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "dialog:allow-ask",
    "shell:allow-spawn",
    "shell:allow-kill"
  ]
}
