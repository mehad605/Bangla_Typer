{
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "remote": {
    "urls": ["http://127.0.0.1:*"]
  },
  "permissions": [
    "core:default",
    "core:window:default",
    "dialog:default",
    "shell:allow-spawn",
    "shell:allow-kill"
  ]
}
